{
  "name": "mediaplayers/jellyfin",
  "description": "Jellyfin Media Server setup configuration",
  "steps": [
    {
      "action": "wait_for_service",
      "description": "Wait for Jellyfin to be ready",
      "params": {
        "service": "jellyfin",
        "port": 8096,
        "timeout": 120
      }
    },
    {
      "action": "log_info",
      "description": "Display Jellyfin access information",
      "params": {
        "message": "Jellyfin is now accessible at http://${SERVER_IP}:8096"
      }
    }
  ]
}
